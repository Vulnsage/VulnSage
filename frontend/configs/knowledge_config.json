[
  {
    "knowledge_id": "agentscope_code_rag",
    "model_config_name": "qwen-plus",
    "emb_model_config_name": "text-embedding-v2",
    "chunk_size": 2048,
    "chunk_overlap": 40,
    "data_processing": [
      {
        "load_data": {
          "loader": {
            "create_object": true,
            "module": "llama_index.core",
            "class": "SimpleDirectoryReader",
            "init_args": {
              "input_dir": "~/fake/",
              "recursive": false,
              "required_exts": [
                ".pdf"
              ]
            }
          }
        }
      }
    ]
  },
  {
    "knowledge_id": "cve_info",
    "model_config_name": "qwen-plus",
    "emb_model_config_name": "text-embedding-v2",
    "chunk_size": 2048,
    "chunk_overlap": 40,
    "data_processing": [
      {
        "load_data": {
          "loader": {
            "create_object": true,
            "module": "llama_index.core",
            "class": "SimpleDirectoryReader",
            "init_args": {
              "input_dir": "./",
              "required_exts": [
                ".md"
              ]
            }
          }
        },
        "store_and_index": {
          "transformations": [
            {
              "create_object": true,
              "module": "llama_index.core.node_parser",
              "class": "SentenceSplitter",
              "init_args": {
                "chunk_size": 1024
              }
            }
          ]
        }
      }
    ]
  }
]